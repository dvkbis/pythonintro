   "source": [
    "def climbStairs(self, n: int) -> int:\n",
    "    if n == 1:\n",
    "        return 1\n",
    "    if n == 2:\n",
    "        return 2\n",
    "\n",
    "    first = 1\n",
    "    second = 2\n",
    "    i = 2\n",
    "    while i < n:\n",
    "        last = first + second\n",
    "        first = second\n",
    "        second = last\n",
    "        i += 1\n",
    "\n",
    "    return second"
   ]
  }
 ],

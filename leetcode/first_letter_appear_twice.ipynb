   "source": [
    "def repeatedCharacter(self, s: str) -> str:\n",
    "    seen = set()\n",
    "\n",
    "    for c in s:\n",
    "        if c in seen:\n",
    "            return c\n",
    "        else:\n",
    "            seen.add(c)\n",
    "\n",
    "    return None"
   ]
  }
 ],
